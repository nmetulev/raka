<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="SampleApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SampleApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="SampleApp"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="SampleApp">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <Grid Grid.Row="1" Padding="24">
            <StackPanel x:Name="MainPanel" Spacing="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="WelcomeText" Text="Welcome to Raka DevTools Sample" FontSize="24" HorizontalAlignment="Center" />
                <TextBox x:Name="NameInput" PlaceholderText="Enter your name" Width="300" />
                <Button x:Name="GreetButton" Content="Say Hello" HorizontalAlignment="Center" Click="GreetButton_Click" />
                <TextBlock x:Name="OutputText" Text="" FontSize="16" HorizontalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                    <CheckBox x:Name="DarkModeCheck" Content="Dark Mode" />
                    <ToggleSwitch x:Name="AnimationToggle" Header="Animations" IsOn="True" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
