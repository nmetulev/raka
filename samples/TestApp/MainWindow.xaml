<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TestApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Raka TestApp">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <NavigationView x:Name="NavView"
                    IsBackButtonVisible="Collapsed"
                    SelectionChanged="NavView_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="NavInput" Content="Input Tests" Tag="input" Icon="Edit" />
            <NavigationViewItem x:Name="NavList" Content="List Tests" Tag="list" Icon="List" />
            <NavigationViewItem x:Name="NavStates" Content="Visual States" Tag="states" Icon="View" />
        </NavigationView.MenuItems>

        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Window>
