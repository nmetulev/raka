<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TestApp.ListTestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24" MaxWidth="600">
            <TextBlock Text="List and Click Tests" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- ListView with IsItemClickEnabled (click should work) -->
            <StackPanel Spacing="8">
                <TextBlock Text="ListView with IsItemClickEnabled" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ListView x:Name="ClickableList" IsItemClickEnabled="True"
                          ItemClick="ClickableList_ItemClick"
                          SelectionMode="None" MaxHeight="200">
                    <ListView.Items>
                        <TextBlock Text="Item 1 — Click me" />
                        <TextBlock Text="Item 2 — Click me" />
                        <TextBlock Text="Item 3 — Click me" />
                        <TextBlock Text="Item 4 — Click me" />
                    </ListView.Items>
                </ListView>
                <TextBlock x:Name="ListClickStatus" Text="Last clicked: none" Foreground="{ThemeResource SystemFillColorNeutralBrush}" />
            </StackPanel>

            <!-- ListView with SelectionChanged -->
            <StackPanel Spacing="8">
                <TextBlock Text="ListView with SelectionChanged" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ListView x:Name="SelectableList" SelectionMode="Single"
                          SelectionChanged="SelectableList_SelectionChanged" MaxHeight="200">
                    <ListView.Items>
                        <TextBlock Text="Option A" />
                        <TextBlock Text="Option B" />
                        <TextBlock Text="Option C" />
                    </ListView.Items>
                </ListView>
                <TextBlock x:Name="SelectionStatus" Text="Selected: none" Foreground="{ThemeResource SystemFillColorNeutralBrush}" />
            </StackPanel>

            <!-- Data-bound text (search test) -->
            <StackPanel Spacing="8">
                <TextBlock Text="Data-bound text (search test)" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ListView x:Name="BoundItems" MaxHeight="120" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Padding="8,4" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
