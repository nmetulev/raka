<Project>

  <!--
    Raka.DevTools: Development-only WinUI 3 automation tool.

    In Debug builds:
      - Defines RAKA_DEVTOOLS preprocessor symbol
      - Assembly is referenced normally

    In Release builds:
      - Symbol is not defined (#if RAKA_DEVTOOLS blocks are excluded)
      - Assembly references are removed (zero runtime footprint)

    Users can override with <RakaDevToolsEnabled>true</RakaDevToolsEnabled>
    to force-enable in any configuration.
  -->

  <PropertyGroup>
    <RakaDevToolsEnabled Condition="'$(RakaDevToolsEnabled)' == '' And '$(Configuration)' == 'Debug'">true</RakaDevToolsEnabled>
    <RakaDevToolsEnabled Condition="'$(RakaDevToolsEnabled)' == ''">false</RakaDevToolsEnabled>
  </PropertyGroup>

  <PropertyGroup Condition="'$(RakaDevToolsEnabled)' == 'true'">
    <DefineConstants>$(DefineConstants);RAKA_DEVTOOLS</DefineConstants>
  </PropertyGroup>

</Project>
