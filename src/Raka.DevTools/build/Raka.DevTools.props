<Project>

  <!--
    Raka.DevTools: Development-only WinUI 3 automation tool.

    Defaults to ENABLED (defines RAKA_DEVTOOLS, includes auto-init source).
    The .targets file strips references and symbols for Release builds,
    where $(Configuration) is guaranteed to be set.

    Users can override:
      <RakaDevToolsEnabled>false</RakaDevToolsEnabled>  to force-disable
      <RakaDevToolsEnabled>true</RakaDevToolsEnabled>   to force-enable (even in Release)
  -->

  <PropertyGroup>
    <RakaDevToolsEnabled Condition="'$(RakaDevToolsEnabled)' == ''">true</RakaDevToolsEnabled>
  </PropertyGroup>

  <PropertyGroup Condition="'$(RakaDevToolsEnabled)' == 'true'">
    <DefineConstants>$(DefineConstants);RAKA_DEVTOOLS</DefineConstants>
  </PropertyGroup>

</Project>
