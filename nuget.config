<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--
      Local source for development: packages built by .\build.ps1 go here.
      NuGet silently skips sources that don't exist, but some tooling (CI, VS)
      treats a missing path as an error. To avoid issues in CI, we only keep
      nuget.org here and add the local source via dotnet CLI when needed:
        dotnet nuget add source ./artifacts/nuget -n local
    -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
